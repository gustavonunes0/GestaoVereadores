# Variáveis para desenvolvimento com Docker Compose (banco local).
# Copie para backend/.env ao rodar API no host com apenas o Postgres no Docker:
#
#   docker compose up postgres -d
#   cp .env.docker.example backend/.env
#
SIGL_USE_LOCAL_DB=true
LOCAL_DATABASE_URL="postgresql://postgres:postgres@localhost:5433/gestao_vereadores?schema=public"

PORT=3000
JWT_SECRET="altere-esta-chave-em-producao"
CORS_ORIGIN="http://localhost:5173,http://localhost:8080,http://127.0.0.1:8080"
