        "@nestjs/jwt": "^11.0.0",
        "@nestjs/mapped-types": "^2.1.1",
        "@nestjs/passport": "^11.0.0",
        "@nestjs/platform-fastify": "^11.1.26",
        "@nestjs/swagger": "^11.0.0",
        "@nestjs/throttler": "^6.4.0",
        "@prisma/client": "^6.0.0",
        "bcryptjs": "^3.0.2",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.1",
        "passport": "^0.7.0",
        "passport-jwt": "^4.0.1",
        "reflect-metadata": "^0.2.2",
