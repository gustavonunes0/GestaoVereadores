        "@types/passport-jwt": "^4.0.1",
        "@types/supertest": "^6.0.2",
        "jest": "^29.7.0",
        "prisma": "^6.0.0",
        "supertest": "^7.0.0",
        "ts-jest": "^29.2.5",
        "ts-node": "^10.9.2",
