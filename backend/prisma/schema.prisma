// Schema derivado da aba "Atividade Legislativa" — Mapeamento_Banco_Dados_IntGest_Cardinalidade_CORRIGIDO.drawio
// Telas de pesquisa (MATERIA_PESQUISAR, SESSAO_PESQUISAR, NORMA_PESQUISAR) são filtros de API, não tabelas.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Multi-tenant (SaaS) ---

enum TenantStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum TenantUserRole {
  OWNER
  ADMIN
  MANAGER
  MEMBER
  VIEWER
}

enum TenantUserStatus {
  ACTIVE
  INVITED
  DISABLED
}

model User {
  id             String       @id @default(uuid())
  firstName      String
  lastName       String
  cpf            String       @unique
  email          String       @unique
  passwordHash   String
  profilePicture String?
  createdAt      DateTime     @default(now())
  createdBy      String?
  modifiedAt     DateTime     @updatedAt
  modifiedBy     String?
  isRemoved      Boolean      @default(false)
  tenantUsers    TenantUser[]
}

model Tenant {
  id          String       @id @default(uuid())
  name        String
  cnpj        String       @unique
  logo        String?
  status      TenantStatus @default(ACTIVE)
  settings    Json?
  createdAt   DateTime     @default(now())
  createdBy   String?
  modifiedAt  DateTime     @updatedAt
  modifiedBy  String?
  isRemoved   Boolean      @default(false)
  tenantUsers TenantUser[]

  parlamentares    Parlamentar[]
  legislaturas     Legislatura[]
  comissoes        Comissao[]
  frentes          FrenteParlamentar[]
  materias         Materia[]
  autores          Autor[]
  normas           Norma[]
  sessoesPlenarias SessaoPlenaria[]
  tiposMateria     TipoMateria[]
  tiposAutor       TipoAutor[]
  tiposSessao      TipoSessao[]
  cargosMesa       CargoMesa[]
  mesasDiretoras   MesaDiretora[]
}

model TenantUser {
  id           String           @id @default(uuid())
  tenantId     String
  tenant       Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId       String
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  role         TenantUserRole   @default(MEMBER)
  status       TenantUserStatus @default(ACTIVE)
  isAdmin      Boolean          @default(false)
  permissions  Json             @default("[]")
  lastAccessAt DateTime?
  createdAt    DateTime         @default(now())
  createdBy    String?
  modifiedAt   DateTime         @updatedAt
  modifiedBy   String?
  isRemoved    Boolean          @default(false)

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([userId])
}

// --- Autenticação SIGL ---

enum RoleUsuario {
  MASTER
  ADMIN
  OPERADOR
}

enum StatusMateria {
  EM_TRAMITACAO
  APROVADA
  REJEITADA
  ARQUIVADA
  RETIRADA
}

enum CodigoSituacaoSessao {
  AGENDADA
  EM_ANDAMENTO
  ENCERRADA
  CANCELADA
}

enum FasePauta {
  GRANDE_EXPEDIENTE
  ORDEM_DO_DIA
  EXPLICACOES_PESSOAIS
}

enum ResultadoPauta {
  APROVADO
  REJEITADO
  RETIRADO
  ADIADO
}

enum TipoVotacao {
  NOMINAL
  SIMBOLICA
  SECRETA
}

enum ResultadoVotacao {
  APROVADO
  REJEITADO
  EMPATADO
}

enum Voto {
  SIM
  NAO
  ABSTENCAO
  PRESENTE
}

enum SituacaoPresenca {
  PRESENTE
  AUSENTE
  JUSTIFICADO
}

model Usuario {
  id           String      @id @default(uuid())
  username     String      @unique
  passwordHash String
  nome         String
  role         RoleUsuario @default(OPERADOR)
  ativo        Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

// --- Domínios auxiliares (tabelas inferidas no drawio) ---

model Ano {
  id        String   @id @default(uuid())
  valor     Int      @unique
  materias  Materia[]
  normas    Norma[]
  createdAt DateTime @default(now())
}

model TipoMateria {
  id        String    @id @default(uuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  nome      String
  materias  Materia[]

  @@unique([tenantId, nome])
  @@index([tenantId])
}

model TipoListagem {
  id       String    @id @default(uuid())
  nome     String    @unique
  materias Materia[]
}

model Tematica {
  id       String    @id @default(uuid())
  nome     String    @unique
  materias Materia[]
}

model OrigemMateria {
  id       String    @id @default(uuid())
  nome     String    @unique
  materias Materia[]
}

model LocalOrigemExterna {
  id       String    @id @default(uuid())
  nome     String    @unique
  materias Materia[]
}

model TipoAutor {
  id        String  @id @default(uuid())
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id])
  nome      String
  autores   Autor[]

  @@unique([tenantId, nome])
  @@index([tenantId])
}

model StatusTramitacao {
  id       String    @id @default(uuid())
  nome     String    @unique
  materias Materia[]
}

model UnidadeTramitacao {
  id       String    @id @default(uuid())
  nome     String    @unique
  materias Materia[]
}

model TipoSessao {
  id               String           @id @default(uuid())
  tenantId         String
  tenant           Tenant           @relation(fields: [tenantId], references: [id])
  nome             String
  requerQuorum     Boolean          @default(true)
  sessoesPlenarias SessaoPlenaria[]

  @@unique([tenantId, nome])
  @@index([tenantId])
}

model SituacaoSessao {
  id               String               @id @default(uuid())
  nome             String               @unique
  codigo           CodigoSituacaoSessao? @unique
  sessoesPlenarias SessaoPlenaria[]
}

model EsferaFederacao {
  id     String @id @default(uuid())
  nome   String @unique
  normas Norma[]
}

model IdentificadorNorma {
  id     String @id @default(uuid())
  nome   String @unique
  normas Norma[]
}

model TipoNorma {
  id     String @id @default(uuid())
  nome   String @unique
  normas Norma[]
}

model ClassificacaoAto {
  id   String @id @default(uuid())
  nome String @unique
  atos Ato[]
}

model TipoAto {
  id   String @id @default(uuid())
  nome String @unique
  atos Ato[]
}

model CargoMesa {
  id        String              @id @default(uuid())
  tenantId  String
  tenant    Tenant              @relation(fields: [tenantId], references: [id])
  nome      String
  membros   MesaDiretoraMembro[]

  @@unique([tenantId, nome])
  @@index([tenantId])
}

// --- Cadastros estruturais ---

model Pessoa {
  id          String       @id @default(uuid())
  nome        String
  cpf         String?      @unique
  email       String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  parlamentar Parlamentar?
}

model Parlamentar {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  pessoaId  String   @unique
  pessoa    Pessoa   @relation(fields: [pessoaId], references: [id], onDelete: Cascade)
  ativo     Boolean  @default(true)
  mensagem  String?
  isRemoved Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])

  autores              Autor[]
  materiasRelator      Materia[]           @relation("RelatorMateria")
  materiasPrimeiroAutor Materia[]           @relation("PrimeiroAutorMateria")
  membrosMesa          MesaDiretoraMembro[]
  membrosComissao      ComissaoMembro[]
  membrosFrente        FrenteMembro[]
  presencas            PresencaSessao[]
  votos                VotoParlamentar[]
}

model Autor {
  id            String       @id @default(uuid())
  tenantId      String
  tenant        Tenant       @relation(fields: [tenantId], references: [id])
  nome          String
  tipoAutorId   String
  tipoAutor     TipoAutor    @relation(fields: [tipoAutorId], references: [id])
  parlamentarId String?
  parlamentar   Parlamentar? @relation(fields: [parlamentarId], references: [id])
  materias       Materia[]      @relation("AutorMateria")
  materiaAutores MateriaAutor[]
  isRemoved      Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([tenantId])
}

model Comissao {
  id        String           @id @default(uuid())
  tenantId  String
  tenant    Tenant           @relation(fields: [tenantId], references: [id])
  nome      String
  mensagem  String?
  ativa     Boolean          @default(true)
  isRemoved Boolean          @default(false)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  membros   ComissaoMembro[]

  @@index([tenantId])
}

model ComissaoMembro {
  id            String      @id @default(uuid())
  comissaoId    String
  comissao      Comissao    @relation(fields: [comissaoId], references: [id], onDelete: Cascade)
  parlamentarId String
  parlamentar   Parlamentar @relation(fields: [parlamentarId], references: [id])
  titular       Boolean     @default(true)
  @@unique([comissaoId, parlamentarId])
}

model FrenteParlamentar {
  id        String         @id @default(uuid())
  tenantId  String
  tenant    Tenant         @relation(fields: [tenantId], references: [id])
  nome      String
  mensagem  String?
  ativa     Boolean        @default(true)
  isRemoved Boolean        @default(false)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  membros   FrenteMembro[]

  @@index([tenantId])
}

model FrenteMembro {
  id            String           @id @default(uuid())
  frenteId      String
  frente        FrenteParlamentar @relation(fields: [frenteId], references: [id], onDelete: Cascade)
  parlamentarId String
  parlamentar   Parlamentar      @relation(fields: [parlamentarId], references: [id])
  @@unique([frenteId, parlamentarId])
}

model Legislatura {
  id         String            @id @default(uuid())
  tenantId   String
  tenant     Tenant            @relation(fields: [tenantId], references: [id])
  numero     Int
  dataInicio DateTime
  dataFim    DateTime?
  isRemoved  Boolean           @default(false)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  sessoesLegislativas SessaoLegislativa[]
  mesasDiretoras     MesaDiretora[]

  @@unique([tenantId, numero])
  @@index([tenantId])
}

model SessaoLegislativa {
  id            String         @id @default(uuid())
  legislaturaId String
  legislatura   Legislatura    @relation(fields: [legislaturaId], references: [id], onDelete: Cascade)
  numero        Int
  dataInicio    DateTime?
  dataFim       DateTime?
  sessoesPlenarias SessaoPlenaria[]
  @@unique([legislaturaId, numero])
}

model SessaoPlenaria {
  id                 String          @id @default(uuid())
  tenantId           String
  tenant             Tenant          @relation(fields: [tenantId], references: [id])
  sessaoLegislativaId String?
  sessaoLegislativa  SessaoLegislativa? @relation(fields: [sessaoLegislativaId], references: [id])
  dataInicio         DateTime
  tipoSessaoId       String
  tipoSessao         TipoSessao      @relation(fields: [tipoSessaoId], references: [id])
  situacaoId         String
  situacao           SituacaoSessao  @relation(fields: [situacaoId], references: [id])
  mensagem           String?
  isRemoved          Boolean         @default(false)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@index([tenantId])
  mesasDiretoras     MesaDiretora[]
  pautaItens         PautaItem[]
  presencas          PresencaSessao[]
}

model MesaDiretora {
  id            String              @id @default(uuid())
  tenantId      String
  tenant        Tenant              @relation(fields: [tenantId], references: [id])
  legislaturaId String
  legislatura   Legislatura         @relation(fields: [legislaturaId], references: [id])
  sessaoId      String?
  sessao        SessaoPlenaria?     @relation(fields: [sessaoId], references: [id])
  mensagem      String?
  isRemoved     Boolean             @default(false)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  membros       MesaDiretoraMembro[]

  @@index([tenantId])
}

model MesaDiretoraMembro {
  id            String      @id @default(uuid())
  mesaId        String
  mesa          MesaDiretora @relation(fields: [mesaId], references: [id], onDelete: Cascade)
  parlamentarId String
  parlamentar   Parlamentar @relation(fields: [parlamentarId], references: [id])
  cargoId       String
  cargo         CargoMesa   @relation(fields: [cargoId], references: [id])
  @@unique([mesaId, cargoId])
}

// --- Processo legislativo ---

model Materia {
  id                         String             @id @default(uuid())
  tenantId                   String
  tenant                     Tenant             @relation(fields: [tenantId], references: [id])
  tipoId                     String
  tipo                       TipoMateria        @relation(fields: [tipoId], references: [id])
  ementa                     String
  numero                     Int?
  numeroProtocolo            Int?
  anoId                      String?
  ano                        Ano?               @relation(fields: [anoId], references: [id])
  tematicaId                 String?
  tematica                   Tematica?          @relation(fields: [tematicaId], references: [id])
  origemId                   String?
  origem                     OrigemMateria?     @relation(fields: [origemId], references: [id])
  tipoListagemId             String?
  tipoListagem               TipoListagem?      @relation(fields: [tipoListagemId], references: [id])
  dataApresentacaoInicio     DateTime?
  dataApresentacaoFim        DateTime?
  dataPublicacaoInicio       DateTime?
  dataPublicacaoFim          DateTime?
  autorId                    String?
  autor                      Autor?             @relation("AutorMateria", fields: [autorId], references: [id])
  primeiroAutorId            String?
  primeiroAutor              Parlamentar?       @relation("PrimeiroAutorMateria", fields: [primeiroAutorId], references: [id])
  relatorId                  String?
  relator                    Parlamentar?       @relation("RelatorMateria", fields: [relatorId], references: [id])
  localOrigemExternaId       String?
  localOrigemExterna         LocalOrigemExterna? @relation(fields: [localOrigemExternaId], references: [id])
  unidadeTramitacaoDestinoId String?
  unidadeTramitacaoDestino   UnidadeTramitacao? @relation(fields: [unidadeTramitacaoDestinoId], references: [id])
  statusTramitacaoId         String?
  statusTramitacao           StatusTramitacao?  @relation(fields: [statusTramitacaoId], references: [id])
  status                     StatusMateria      @default(EM_TRAMITACAO)
  tramitacaoJson             Json               @default("[]")
  emTramitacao               Boolean            @default(true)
  mensagem                   String?
  isRemoved                  Boolean            @default(false)
  createdAt                  DateTime           @default(now())
  updatedAt                  DateTime           @updatedAt
  pautaItens                 PautaItem[]
  materiaAutores             MateriaAutor[]
  normas                     Norma[]

  @@unique([tenantId, tipoId, numero, anoId])
  @@index([tenantId])
  @@index([tenantId, status])
}

model Norma {
  id                   String             @id @default(uuid())
  tenantId             String
  tenant               Tenant             @relation(fields: [tenantId], references: [id])
  tipoId               String
  tipo                 TipoNorma          @relation(fields: [tipoId], references: [id])
  numero               String
  anoId                String?
  ano                  Ano?               @relation(fields: [anoId], references: [id])
  data                 DateTime?
  dataPublicacaoInicio DateTime?
  dataPublicacaoFim    DateTime?
  esferaFederacaoId    String?
  esferaFederacao      EsferaFederacao?   @relation(fields: [esferaFederacaoId], references: [id])
  ementa               String
  identificadorId      String?
  identificador        IdentificadorNorma? @relation(fields: [identificadorId], references: [id])
  materiaOrigemId      String?
  materiaOrigem        Materia?           @relation(fields: [materiaOrigemId], references: [id])
  mensagem             String?
  isRemoved            Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([tenantId])
}

model Ato {
  id                   String           @id @default(uuid())
  tipoId               String
  tipo                 TipoAto          @relation(fields: [tipoId], references: [id])
  classificacaoId      String
  classificacao        ClassificacaoAto @relation(fields: [classificacaoId], references: [id])
  numero               String
  dataInicio           DateTime?
  dataFim              DateTime?
  dataPublicacaoInicio DateTime?
  dataPublicacaoFim    DateTime?
  mensagem             String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
}

// --- Sessão plenária (telas SESSAO_186/187/188 → pauta e presença) ---

model MateriaAutor {
  id        String  @id @default(uuid())
  materiaId String
  materia   Materia @relation(fields: [materiaId], references: [id], onDelete: Cascade)
  autorId   String
  autor     Autor   @relation(fields: [autorId], references: [id])
  ordem     Int

  @@unique([materiaId, autorId])
  @@unique([materiaId, ordem])
}

model PautaItem {
  id         String          @id @default(uuid())
  sessaoId   String
  sessao     SessaoPlenaria  @relation(fields: [sessaoId], references: [id], onDelete: Cascade)
  materiaId  String
  materia    Materia         @relation(fields: [materiaId], references: [id])
  ordem      Int
  fase       FasePauta       @default(ORDEM_DO_DIA)
  resultado  ResultadoPauta?
  isRemoved  Boolean         @default(false)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  votacao    Votacao?

  @@unique([sessaoId, materiaId])
  @@unique([sessaoId, ordem])
}

model Votacao {
  id          String            @id @default(uuid())
  pautaItemId String            @unique
  pautaItem   PautaItem         @relation(fields: [pautaItemId], references: [id], onDelete: Cascade)
  tipoVotacao TipoVotacao
  votosSim    Int               @default(0)
  votosNao    Int               @default(0)
  abstencoes  Int               @default(0)
  resultado   ResultadoVotacao?
  realizadaAt DateTime?
  createdAt   DateTime          @default(now())
  votos       VotoParlamentar[]
}

model VotoParlamentar {
  id            String    @id @default(uuid())
  votacaoId     String
  votacao       Votacao   @relation(fields: [votacaoId], references: [id], onDelete: Cascade)
  parlamentarId String
  parlamentar   Parlamentar @relation(fields: [parlamentarId], references: [id])
  voto          Voto

  @@unique([votacaoId, parlamentarId])
}

model PresencaSessao {
  id            String            @id @default(uuid())
  sessaoId      String
  sessao        SessaoPlenaria    @relation(fields: [sessaoId], references: [id], onDelete: Cascade)
  parlamentarId String
  parlamentar   Parlamentar       @relation(fields: [parlamentarId], references: [id])
  presente      Boolean           @default(true)
  situacao      SituacaoPresenca  @default(PRESENTE)
  justificativa String?
  createdAt     DateTime          @default(now())

  @@unique([sessaoId, parlamentarId])
}
