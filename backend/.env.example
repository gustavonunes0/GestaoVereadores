# ── Desenvolvimento local (postgres do docker compose na raiz, porta 5433 no host) ──
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/gestao_vereadores?schema=public"
DIRECT_DATABASE_URL="postgresql://postgres:postgres@localhost:5433/gestao_vereadores?schema=public"

PORT=3000
JWT_SECRET="altere-esta-chave-em-producao"
CORS_ORIGIN="http://localhost:5173,http://localhost:8080,http://127.0.0.1:8080"

# ── Vercel (projeto backend gestao-vereadores-jdes) ──
# DATABASE_URL              ← gestaovereadores_PRISMA_DATABASE_URL
# DIRECT_DATABASE_URL       ← gestaovereadores_POSTGRES_URL
# JWT_SECRET                ← chave forte (obrigatório)
# CORS_ORIGIN               ← https://gestao-vereadores.vercel.app
# gestaovereadores_PRISMA_DATABASE_URL  →  DATABASE_URL        (runtime, com pool)
# gestaovereadores_POSTGRES_URL         →  DIRECT_DATABASE_URL (migrations)
#
# Exemplo após renomear:
# DATABASE_URL="postgres://...@db.prisma.io/..."
# DIRECT_DATABASE_URL="postgres://...@db.prisma.io/..."
