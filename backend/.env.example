# PostgreSQL — desenvolvimento local (postgres do docker compose na raiz)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/gestao_vereadores?schema=public"

PORT=3000
JWT_SECRET="altere-esta-chave-em-producao"
CORS_ORIGIN="http://localhost:5173,http://localhost:8080,http://127.0.0.1:8080"

# --------------------------------------------------------------------------
# Jitsi (transmissão das sessões)
# SEM estas variáveis o backend usa o servidor público meet.jit.si, que é
# apenas demonstração e desliga a chamada em 5 minutos. Configure o Jitsi
# self-hosted do docker-compose da raiz e aponte aqui:
#
#   JITSI_DOMAIN   -> host:porta que o NAVEGADOR acessa (não use container).
#                     Local: localhost:8443 · Rede/app: <IP_LAN>:8443
#   JITSI_APP_ID   -> deve ser IGUAL ao JWT_APP_ID do .env da raiz
#   JITSI_APP_SECRET-> deve ser IGUAL ao JWT_APP_SECRET do .env da raiz
#   JITSI_SUB      -> domínio XMPP do Jitsi self-hosted (meet.jitsi)
# --------------------------------------------------------------------------
JITSI_DOMAIN="localhost:8444"
JITSI_APP_ID="gestao_vereadores"
JITSI_APP_SECRET="troque-por-um-segredo-forte-de-32-bytes"
JITSI_SUB="meet.jitsi"
