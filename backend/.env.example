# ── Vercel Storage (injetadas automaticamente — NÃO precisa renomear) ──
# gestaovereadores_PRISMA_DATABASE_URL  →  mapeada para DATABASE_URL
# gestaovereadores_POSTGRES_URL         →  mapeada para DIRECT_DATABASE_URL
#
# Ainda configure manualmente no projeto backend:
# JWT_SECRET=chave-forte-aleatoria
# CORS_ORIGIN=https://gestao-vereadores.vercel.app
