# ==========================================================================
# Variáveis do docker-compose RAIZ (postgres + api + frontend + Jitsi)
# Copie para .env:  cp .env.example .env
# ==========================================================================

# IP da sua máquina na rede local (LAN). OBRIGATÓRIO para que a web E o app
# mobile (em outro dispositivo) consigam acessar a sala Jitsi.
# Descubra com:  ipconfig (Windows) / ip addr (Linux) / ifconfig (Mac)
# Ex.: 192.168.100.7   — NÃO use "localhost" se for testar no celular.
JITSI_PUBLIC_HOST=192.168.100.7     # seu IP LAN (ipconfig). Use localhost só p/ testar no próprio PC
DOCKER_HOST_ADDRESS=192.168.100.7  

# Portas do Jitsi expostas no host
JITSI_HTTP_PORT=8000
JITSI_HTTPS_PORT=8444
JVB_PORT=10000

TZ=America/Sao_Paulo

# --------------------------------------------------------------------------
# JWT — DEVEM bater com o backend (JITSI_APP_ID / JITSI_APP_SECRET).
# Gere o secret com:  openssl rand -hex 32
# --------------------------------------------------------------------------
JWT_APP_ID=gestao_vereadores
JWT_APP_SECRET=troque-por-um-segredo-forte-de-32-bytes

# --------------------------------------------------------------------------
# Senhas internas dos componentes (gere com: openssl rand -hex 16)
# --------------------------------------------------------------------------
JICOFO_AUTH_PASSWORD=troque-jicofo
JVB_AUTH_PASSWORD=troque-jvb
JIGASI_XMPP_PASSWORD=troque-jigasi
JIBRI_RECORDER_PASSWORD=troque-jibri-recorder
JIBRI_XMPP_PASSWORD=troque-jibri
